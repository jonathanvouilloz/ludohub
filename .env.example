# Neon Postgres (serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/ludohub?sslmode=require

# Better Auth — générer avec: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# URL publique de l'app (sans slash final)
PUBLIC_APP_URL=http://localhost:5173

# Super Admin (Jonathan)
SUPER_ADMIN_PASSWORD=your-admin-password-here

# Newsletter (Resend) — domaine ludohub.ch vérifié dans Resend
RESEND_API_KEY=re_xxx
NEWSLETTER_FROM=noreply@ludohub.ch
# Secret de signature des webhooks Resend (bounces/plaintes) — Svix
RESEND_WEBHOOK_SECRET=whsec_xxx
